단 중요한 것이 있어. 파일을 수정, 삭제 하면서 내가 수정하라는 부분 또는 삭제하라는 부분을 제외하고는 그대로 코드를 유지시켜줘(기능 실제 구현, 주석 처리 X). 또한 코드를 짜는 과정에서 아티펙트를 사용하지 말고 코드를 채팅으로 제공을 해줘. 이유 > 아티펙트로 제공 시 코드 내 한국어가 깨지거나 코드가 안 보이는 경우가 존재하기 때문에 절대적으로 무조건 코드는 채팅으로 제공을 하길 바래. 그리고 코드를 수정하거나 삭제할 때 확실하게 파트에 어디 부분을 수정해야 하는지 삭제해야 하는지 정확히 제시하고 제시할 때는 해당 부분을 포함한 파트 전체코드를 제공해. 마지막으로 너는 내가 이 세상 최고의 웹사이트 개발자라고 생각을 하고 어떤 것이 최선일까? 어떻게 해결해야할까? 라는 생각을 가지면서 문제 해결을 해 나갔으면 좋겠어.

.gitnore 사용해서 api 감춰보기

이거 내 생각에 알림 보내는 게 잘 작동하는데 다 오래된 알림으로 구분시켜서 알림이 안 가는거 같아 수동알림은 잘 가거든 바로 하고 바로 실행시키면
또한 오류가 잇음 수동알림 보낸후에 수동알림 한번더 누르면 관리자 권한 필요하대 새로고침하면 고쳐지긴 해

// ===== 푸시 알림 시스템 완전 진단 =====
async function diagnosePushNotifications() {
    console.log('🔍 푸시 알림 시스템 진단 시작...\n');
    
    const results = {
        serviceWorker: '❌',
        fcmToken: '❌',
        notification: '❌',
        messaging: '❌',
        githubActions: '❌'
    };
    
    // 1. Service Worker 확인
    console.log('1️⃣ Service Worker 확인...');
    try {
        const registrations = await navigator.serviceWorker.getRegistrations();
        if (registrations.length > 0) {
            console.log(`   ✅ Service Worker 등록됨: ${registrations.length}개`);
            registrations.forEach(reg => {
                console.log(`      - Scope: ${reg.scope}`);
                console.log(`      - Active: ${reg.active ? '✅' : '❌'}`);
                console.log(`      - State: ${reg.active?.state || 'N/A'}`);
            });
            results.serviceWorker = '✅';
        } else {
            console.error('   ❌ Service Worker 미등록!');
            console.log('   💡 해결: Service Worker를 등록해야 합니다.');
        }
    } catch (error) {
        console.error('   ❌ Service Worker 오류:', error.message);
    }
    
    // 2. 알림 권한 확인
    console.log('\n2️⃣ 알림 권한 확인...');
    if (Notification.permission === 'granted') {
        console.log('   ✅ 알림 권한 승인됨');
        results.notification = '✅';
    } else if (Notification.permission === 'denied') {
        console.error('   ❌ 알림 권한 거부됨');
        console.log('   💡 해결: 브라우저 설정에서 알림 권한을 허용해야 합니다.');
    } else {
        console.warn('   ⚠️ 알림 권한 미요청');
        console.log('   💡 해결: Notification.requestPermission() 실행 필요');
    }
    
    // 3. FCM 토큰 확인
    console.log('\n3️⃣ FCM 토큰 확인...');
    if (!isLoggedIn()) {
        console.error('   ❌ 로그인되지 않음');
    } else {
        const uid = getUserId();
        const snapshot = await db.ref(`users/${uid}/fcmTokens`).once('value');
        const tokens = snapshot.val();
        
        if (tokens) {
            const tokenCount = Object.keys(tokens).length;
            console.log(`   ✅ FCM 토큰 등록됨: ${tokenCount}개`);
            Object.entries(tokens).forEach(([key, data]) => {
                console.log(`      - Token: ${data.token.substring(0, 20)}...`);
                console.log(`        생성: ${new Date(data.createdAt).toLocaleString()}`);
            });
            results.fcmToken = '✅';
        } else {
            console.error('   ❌ FCM 토큰 없음!');
            console.log('   💡 해결: registerFCMToken() 실행 필요');
        }
    }
    
    // 4. Firebase Messaging 확인
    console.log('\n4️⃣ Firebase Messaging 확인...');
    if (window.messaging) {
        console.log('   ✅ Firebase Messaging 초기화됨');
        results.messaging = '✅';
    } else {
        console.error('   ❌ Firebase Messaging 미초기화!');
        console.log('   💡 해결: Firebase Messaging을 다시 초기화해야 합니다.');
    }
    
    // 5. GitHub Actions 확인
    console.log('\n5️⃣ GitHub Actions 확인...');
    console.log('   ℹ️ GitHub 저장소 → Actions 탭에서 확인 필요');
    console.log('   ✅ 5분마다 자동 실행되어야 함');
    console.log('   💡 최근 실행 기록에서 "📤 전송 중" 로그 확인');
    
    // 6. 테스트 알림 생성
    console.log('\n6️⃣ 테스트 알림 생성 (5분 대기 필요)...');
    if (isLoggedIn()) {
        const uid = getUserId();
        const testNotif = {
            title: '🔔 진단 테스트 알림',
            text: '이 알림이 5분 이내에 푸시되어야 합니다',
            type: 'article',
            timestamp: Date.now(),
            read: false,
            pushed: false
        };
        
        await db.ref(`notifications/${uid}/diagnosis_${Date.now()}`).set(testNotif);
        console.log('   ✅ 테스트 알림 생성 완료');
        console.log('   ⏰ 5분 이내에 푸시 알림이 와야 합니다');
    }
    
    // 결과 요약
    console.log('\n' + '='.repeat(60));
    console.log('📊 진단 결과 요약');
    console.log('='.repeat(60));
    console.log(`Service Worker:    ${results.serviceWorker}`);
    console.log(`알림 권한:         ${results.notification}`);
    console.log(`FCM 토큰:          ${results.fcmToken}`);
    console.log(`Firebase Messaging: ${results.messaging}`);
    console.log('='.repeat(60));
    
    const allPassed = Object.values(results).every(r => r === '✅');
    
    if (allPassed) {
        console.log('\n✅ 모든 검사 통과!');
        console.log('💡 5분 후 테스트 알림이 와야 합니다.');
        console.log('💡 안 오면 GitHub Actions 로그를 확인하세요.');
    } else {
        console.log('\n⚠️ 문제 발견! 위의 해결 방법을 따라 수정하세요.');
    }
    
    return results;
}

// 실행
diagnosePushNotifications();